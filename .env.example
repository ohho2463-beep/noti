# Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Dashboard → Authentication → URL Configuration
# - Site URL: http://localhost:3000 (개발)
# - Redirect URLs: http://localhost:3000/auth/callback

# 워크스페이스 초대 링크 등 절대 URL (프로덕션에서는 실제 도메인)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# (선택) 약관·개인정보처리방침 페이지에 노출할 고객 문의 메일
# NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# 사이트 운영 콘솔(/dashboard/admin) 암호 게이트 (설정 시 입장에 필요)
# ADMIN_CONSOLE_PASSWORD=

# 서비스 롤 키 (크론·관리 콘솔 등, 서버 전용 — 클라이언트에 넣지 마세요)
# Supabase → Project Settings → API → service_role | 로컬: npx supabase status 의 Secret
SUPABASE_SERVICE_ROLE_KEY=

# --- 일정 알림 크론 (로컬에서 401 없이 테스트하려면 필수) ---
# curl: curl -H "Authorization: Bearer $CRON_SECRET" http://localhost:3000/api/cron/schedule-dday
# Vercel: Project → Settings → Environment Variables 에 프로덕션용 값(임의 긴 문자열) 저장
CRON_SECRET=local-dev-cron-secret-change-in-production

# D-day·리마인더 메일 (https://resend.com API 키). 없으면 메일만 생략, 인앱 알림은 동작
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Noti <onboarding@resend.dev>
